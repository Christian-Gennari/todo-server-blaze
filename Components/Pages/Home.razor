@inject TodoState todoState
@page "/"

<PageTitle>Home</PageTitle>

<div class="wrapper">
    <button class="add-input" @onclick="AddTask">Skapa ny</button>

    <div class="input-wrapper">
        @foreach(var task in todoState.Todos)
        {
            <div class="task-row">
                <input class="
                    @(task.IsChecked ? "readonly-text" : "input-text")"
                     readonly="@task.IsChecked"
                     value="@task.Content" @onchange="e => todoState.AddTodo
                     k(task, e.Value?.ToString())" />
                <input 
                    class="checkbox" 
                    type="checkbox" 
                    checked="@task.IsChecked" @onchange="e => UpdateCheck(task, e.Value is bool isChecked && isChecked)" />
            </div>
        }
    </div>
</div>