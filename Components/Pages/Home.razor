@inject TodoState todoState
@rendermode InteractiveServer
@page "/"

<PageTitle>Home</PageTitle>

<div class="wrapper">
    <button class="add-input" @onclick="CreateNewTodo">Skapa ny</button>

    <div class="input-wrapper">
        @foreach(var task in todoState.Todos)
        {
            <div class="task-row">
                <input class="
                    @(task.IsChecked ? "readonly-text" : "input-text")"
                     readonly="@task.IsChecked"
                     @bind="@task.Content" @bind:after="todoState.NotifyStateChanged" @bind:event="oninput" />
                <input 
                    class="checkbox" 
                    type="checkbox" 
                    @bind="@task.IsChecked" @bind:after="todoState.NotifyStateChanged" />
            </div>
        }
    </div>
</div>

@code {

    protected override void OnInitialized()
    {
       todoState.OnChange += OnChangeCallback;
    }

    private void OnChangeCallback() {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() {
        todoState.OnChange -= OnChangeCallback;
    }

    private void CreateNewTodo()
    {
        var newtodo = new TodoDTO("", false);
        todoState.AddTodo(newtodo);
    }
}